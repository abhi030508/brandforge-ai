# =============================================================================
# BrandForge AI - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# =============================================================================
# IBM watsonx.ai Configuration (PRIMARY PROVIDER)
# =============================================================================
# Get your credentials from: https://cloud.ibm.com/
# This application uses IBM watsonx.ai with Granite models

# IBM watsonx.ai API Key (REQUIRED)
WATSONX_API_KEY=your-watsonx-api-key-here

# IBM watsonx.ai Project ID (REQUIRED)
# Find this in your watsonx.ai project settings
WATSONX_PROJECT_ID=your-project-id-here

# Note: The application uses ibm/granite-13b-chat-v2 model by default
# This is configured in the API route and optimized for marketing strategy generation

# =============================================================================
# Custom OpenAI-Compatible Endpoint Configuration
# =============================================================================
# Use this section for other LLM providers that support OpenAI API format
# Examples: Azure OpenAI, LocalAI, Ollama, etc.

# Custom LLM Base URL
# LLM_BASE_URL=https://your-custom-llm-endpoint.com/v1

# Custom Model Name
# MODEL_NAME=your-model-name

# API Key for Custom Endpoint
# OPENAI_API_KEY=your-custom-api-key

# =============================================================================
# Model Configuration (Optional)
# =============================================================================
# Override the default model (gpt-4) with your preferred model
# OpenAI options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# IBM options: ibm/granite-13b-chat-v2, ibm/granite-13b-instruct-v2
# MODEL_NAME=gpt-4

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================
# Temperature for AI responses (0.0 - 1.0, default: 0.7)
# Higher = more creative, Lower = more focused
# AI_TEMPERATURE=0.7

# Maximum tokens for AI responses (default: 2000)
# AI_MAX_TOKENS=2000

# =============================================================================
# Notes
# =============================================================================
# 1. For OpenAI: Only OPENAI_API_KEY is required
# 2. For IBM watsonx.ai: Set WATSONX_API_KEY, LLM_BASE_URL, and MODEL_NAME
# 3. For custom endpoints: Set LLM_BASE_URL, MODEL_NAME, and OPENAI_API_KEY
# 4. Environment variables in .env.local override these defaults
# 5. Restart your development server after changing environment variables